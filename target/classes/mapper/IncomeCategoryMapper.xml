<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.billmanager.jizhang.mapper.IncomeCategoryMapper">

    <resultMap id="BaseResultMap" type="com.billmanager.jizhang.entity.IncomeCategory">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.billmanager.jizhang.entity.IncomeCategory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO income_category (user_id, name, description)
        VALUES (#{userId}, #{name}, #{description})
    </insert>

    <update id="update" parameterType="com.billmanager.jizhang.entity.IncomeCategory">
        UPDATE income_category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            update_time = CURRENT_TIMESTAMP
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM income_category WHERE id = #{id}
    </delete>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM income_category WHERE id = #{id}
    </select>

    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT * FROM income_category WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="findByUserIdAndName" resultMap="BaseResultMap">
        SELECT * FROM income_category 
        WHERE user_id = #{userId} 
        AND name = #{name}
    </select>

</mapper>
